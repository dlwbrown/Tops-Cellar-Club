# ---- CLIENT (public-safe; goes in js/config.js or Netlify build env) ----
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_ANON_KEY=YOUR-ANON-KEY
VAPID_PUBLIC_KEY=YOUR-VAPID-PUBLIC-KEY

# ---- SERVER (SECRET — Supabase Edge Function secrets ONLY, never in the client) ----
# Set with:  supabase secrets set KEY=value
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY   # auto-injected in functions; do not expose
VAPID_PRIVATE_KEY=YOUR-VAPID-PRIVATE-KEY
VAPID_SUBJECT=mailto:ashley@duncanbrown.co.za
ANTHROPIC_API_KEY=sk-ant-...                      # for the generate-post function

# Generate a VAPID keypair once with:  npx web-push generate-vapid-keys
